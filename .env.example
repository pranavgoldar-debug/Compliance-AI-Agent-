# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# ---------------------------------------------------------------------------
# Required in production
# ---------------------------------------------------------------------------
# 32+ char random string. The app auto-generates one for local dev, but in
# prod you MUST set this — otherwise every server restart invalidates every
# user's session cookie.
# APP_SECRET=

# Public base URL of the app. Used to build password-reset links and the
# topbar mode badge tooltip. Defaults to http://127.0.0.1:8000 in dev.
# COMPLIANCE_BASE_URL=https://aspora-compliance.example.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite is the default — no config required.
# To use Postgres, install the extras (`pip install -e ".[postgres]"`) and:
# COMPLIANCE_DB_URL=postgresql+psycopg2://user:pass@host:5432/dbname
#
# Render / Heroku-style postgres:// URLs are auto-rewritten.
# COMPLIANCE_DB_POOL_SIZE=5
# COMPLIANCE_DB_MAX_OVERFLOW=5

# ---------------------------------------------------------------------------
# AI (optional — gates the Claude features behind a single flag)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# COMPLIANCE_AGENT_LIVE=1

# ---------------------------------------------------------------------------
# Email — Phase 8 password reset
# ---------------------------------------------------------------------------
# Without these, /api/auth/forgot-password logs the reset link to the server
# console AND returns it in the response (dev mode), so you can still test
# without a mailer. Set them in prod to actually deliver email.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=
# SMTP_FROM="Aspora Compliance <no-reply@aspora.com>"
# SMTP_TLS=1

# ---------------------------------------------------------------------------
# Other tunables
# ---------------------------------------------------------------------------
# Document uploads root (defaults to ./uploads). Point at a persistent disk
# in prod so the files survive container restarts.
# COMPLIANCE_UPLOADS_DIR=/var/lib/aspora/uploads

# Audit log retention window (min 30, default 365). Admin UI surfaces this.
# COMPLIANCE_AUDIT_RETENTION_DAYS=365
