# Frontend build-time config (Vite). Copy to `.env.local` for local overrides.
#
# Split deploy only: the API origin when the frontend is hosted separately
# (e.g. on Vercel) from the FastAPI backend. Leave unset for local dev and the
# single-origin bundled deploy — the app then makes same-origin relative calls.
#
# VITE_API_BASE_URL=https://api.aspora.com
